.tab-bar {
  display: flex;
  background: #ffffff;
  border-top: 1rpx solid #e0e0e0;
  padding: 8rpx 0 env(safe-area-inset-bottom);
  height: 110rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.tab-icon {
  font-size: 44rpx;
  line-height: 1.2;
}

.tab-label {
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.tab-item.active .tab-label {
  color: #1677ff;
  font-weight: 600;
}

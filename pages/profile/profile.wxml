 <view class="container">
   
 
   <scroll-view class="content" scroll-y>
     <!-- 用户信息卡片 -->
     <view class="user-card">
       <view class="user-avatar">👤</view>
       <view class="user-info">
         <text class="user-name">{{userInfo.username || '未登录'}}</text>
         <text class="user-id" wx:if="{{userInfo.username}}">学号：{{userInfo.username}}</text>
       </view>
       <view class="user-login-btn" wx:if="{{!userInfo.username}}" bindtap="goLogin">去登录</view>
     </view>
 
     <!-- 数据统计 -->
     <view class="stats-row">
       <view class="stat-item">
         <text class="stat-num">{{stats.totalFiles}}</text>
         <text class="stat-label">数据文件</text>
       </view>
       <view class="stat-item">
         <text class="stat-num">{{stats.noticeCount}}</text>
         <text class="stat-label">系统通知</text>
       </view>
       <view class="stat-item">
         <text class="stat-num">{{stats.faqCount}}</text>
         <text class="stat-label">常见问题</text>
       </view>
     </view>
 
      <!-- 功能菜单 -->
      <view class="menu-group">
        <view class="menu-item" bindtap="onRefreshData">
          <text class="menu-icon">🔄</text>
          <text class="menu-text">刷新学习数据</text>
          <text class="menu-arrow">›</text>
        </view>
        <view class="menu-item" bindtap="onClearCache">
          <text class="menu-icon">🗑️</text>
          <text class="menu-text">清除缓存</text>
          <text class="menu-arrow">›</text>
        </view>
      </view>
 
     <view class="menu-group">
       <view class="menu-item" bindtap="onAbout">
         <text class="menu-icon">ℹ️</text>
         <text class="menu-text">关于系统</text>
         <text class="menu-arrow">›</text>
       </view>
     </view>
 
     <!-- 退出登录 -->
     <view wx:if="{{userInfo.username}}" class="logout-btn" bindtap="onLogout">
       <text>退出登录</text>
     </view>
 
     <view class="version-info">
       <text>校园信息智能查询智能体 v2.0</text>
     </view>
   </scroll-view>
 </view>

  .container { height: 100vh; background: #f5f5f5; display: flex; flex-direction: column; padding-bottom: 120rpx; box-sizing: border-box; }
 
 .header {
   display: flex;
   align-items: center;
   justify-content: space-between;
   height: 88rpx;
   background: #1677ff;
   padding: 0 24rpx;
   position: sticky;
   top: 0;
   z-index: 100;
 }
 .back-btn { width: 64rpx; height: 64rpx; display: flex; align-items: center; justify-content: center; }
 .back-btn:active { opacity: 0.6; }
 .back-icon { font-size: 40rpx; color: #fff; }
 .header-title { position: absolute; left: 50%; transform: translateX(-50%); font-size: 34rpx; font-weight: bold; color: #fff; white-space: nowrap; }
 .header-right { width: 64rpx; }
 
  .content { flex: 1; padding: 0 24rpx 40rpx; }
 
 .user-card {
   display: flex;
   align-items: center;
   background: linear-gradient(135deg, #1677ff, #0958d9);
   border-radius: 20rpx;
   padding: 32rpx;
   margin-bottom: 24rpx;
   color: #fff;
   gap: 24rpx;
 }
 .user-avatar { font-size: 72rpx; width: 88rpx; height: 88rpx; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.2); border-radius: 50%; }
 .user-info { flex: 1; }
 .user-name { font-size: 36rpx; font-weight: bold; display: block; margin-bottom: 4rpx; }
 .user-id { font-size: 26rpx; opacity: 0.85; }
 .user-login-btn { padding: 12rpx 28rpx; background: rgba(255,255,255,0.25); border-radius: 40rpx; font-size: 26rpx; }
 .user-login-btn:active { opacity: 0.7; }
 
 .stats-row {
   display: flex;
   background: #fff;
   border-radius: 16rpx;
   padding: 24rpx;
   margin-bottom: 24rpx;
   box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
 }
 .stat-item { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
 .stat-num { font-size: 40rpx; font-weight: bold; color: #1677ff; }
 .stat-label { font-size: 24rpx; color: #999; }
 
 .menu-group {
   background: #fff;
   border-radius: 16rpx;
   margin-bottom: 24rpx;
   box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
   overflow: hidden;
 }
 
 .menu-item {
   display: flex;
   align-items: center;
   padding: 28rpx 24rpx;
   border-bottom: 2rpx solid #f5f5f5;
   gap: 20rpx;
 }
 .menu-item:last-child { border-bottom: none; }
 .menu-item:active { background: #f9f9f9; }
 
 .menu-icon { font-size: 36rpx; width: 44rpx; text-align: center; }
 .menu-text { flex: 1; font-size: 30rpx; color: #333; }
 .menu-arrow { font-size: 36rpx; color: #ccc; }
 
 .logout-btn {
   background: #fff;
   border-radius: 16rpx;
   padding: 28rpx;
   text-align: center;
   font-size: 30rpx;
   color: #e53935;
   margin-bottom: 24rpx;
   box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
 }
 .logout-btn:active { background: #fef2f2; }
 
 .version-info { text-align: center; font-size: 24rpx; color: #ccc; padding: 20rpx 0; }
